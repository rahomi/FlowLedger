# FlowLedger Configuration

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=flowledger
DB_SSL=false

# Application Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Security Configuration
JWT_SECRET=your-very-strong-secret-key-here
JWT_EXPIRES_IN=1d

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5mb
ALLOWED_FILE_TYPES=.pdf,.jpg,.png,.jpeg

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15 * 60 * 1000
RATE_LIMIT_MAX=100

# CORS Configuration
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PATCH,DELETE,PUT
CORS_CREDENTIALS=true